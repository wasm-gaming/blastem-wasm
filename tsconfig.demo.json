{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": "src/demo",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@wasm-gaming/blastem-wasm": ["./dist/blastem/blastem.sdk.d.ts"]
    }
  },
  "include": ["src/demo/**/*.ts"]
}
